{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "ingest": "ts-node --transpile-only src/scripts/ingest.ts",
    "ingest:synthea": "ts-node --transpile-only src/scripts/ingest-synthea.ts",
    "synthesize:notes": "ts-node --transpile-only src/scripts/synthesize-notes.ts",
    "smoke:bedrock": "ts-node --transpile-only src/scripts/smoke-bedrock.ts",
    "smoke:tools": "ts-node --transpile-only src/scripts/smoke-tools.ts",
    "smoke:query": "ts-node --transpile-only src/scripts/smoke-query.ts",
    "smoke:stream": "ts-node --transpile-only src/scripts/smoke-stream.ts",
    "eval": "ts-node --transpile-only src/scripts/run-eval.ts"
  },
  "dependencies": {
    "@aws-rag/shared": "workspace:*",
    "@aws-lambda-powertools/logger": "^2.10.0",
    "@aws-lambda-powertools/metrics": "^2.10.0",
    "@aws-lambda-powertools/tracer": "^2.10.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.1045.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "p-limit": "^6.1.0",
    "pdf-parse": "^1.1.1",
    "pgvector": "^0.2.0",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stream-json": "^2.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/stream-json": "^1.7.8",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
