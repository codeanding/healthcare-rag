# ----------------------------------------------------------------------------
# Local Postgres (docker-compose). Override only if running Postgres elsewhere.
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://dev:dev@localhost:5432/healthcare_rag

# ----------------------------------------------------------------------------
# AWS — preferred path: named profile from ~/.aws/credentials.
# The SDK's default credential chain picks up AWS_PROFILE automatically.
# ----------------------------------------------------------------------------
AWS_PROFILE=codeanding
AWS_REGION=us-west-2

# Alternative: explicit access keys (overrides AWS_PROFILE if both are set).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# ----------------------------------------------------------------------------
# Bedrock model IDs
# ----------------------------------------------------------------------------
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
# Use the cross-region inference profile (with us./eu./apac. prefix) when invoking
# Claude on Bedrock — bare foundation-model ids are blocked in many regions.
BEDROCK_LLM_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_NOTE_SYNTH_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ----------------------------------------------------------------------------
# S3 — set once the Terraform bucket exists; only required for s3:// ingestion.
# ----------------------------------------------------------------------------
S3_DOCUMENTS_BUCKET=
